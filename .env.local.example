# Shopify
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
NEXT_PUBLIC_SHOPIFY_STOREFRONT_ACCESS_TOKEN=placeholder_token

# Sanity
NEXT_PUBLIC_SANITY_PROJECT_ID=placeholder_id
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=placeholder_token

# Formspree
NEXT_PUBLIC_FORMSPREE_ID=placeholder_id

# Demo Mode (set to false when Shopify/Sanity are connected)
NEXT_PUBLIC_USE_DEMO_DATA=true
